<aside class="sidebar" data-controller="sidebar"
       data-action="sortable:move->sidebar#handleToolMove"
       data-mobile-sidebar-target="sidebar">
  <%# ── Logo ── %>
  <div class="px-3 py-2.5 border-b border-border-light flex items-center gap-1">
    <%= link_to root_path, class: "flex items-center gap-2 flex-1 min-w-0", data: { action: "click->mobile-sidebar#navigate" } do %>
      <img src="<%= app_logo_path %>" alt="<%= app_name %>" class="w-7 h-7 flex-shrink-0">
      <span class="font-semibold text-base text-text-primary truncate"><%= app_name %></span>
    <% end %>

    <%# Add menu — lives here so the bottom bar stays uncluttered %>
    <button type="button"
            class="sidebar-add-btn flex-shrink-0"
            popovertarget="sidebar-add-menu"
            style="anchor-name: --sidebar-add-btn"
            title="Add tool or group">
      <%= render "shared/icon", name: "plus", size: 16 %>
    </button>

    <button type="button" class="sidebar-close-btn flex-shrink-0" data-action="click->mobile-sidebar#close">
      <%= render "shared/icon", name: "x", size: 20 %>
    </button>
  </div>

  <%# ── Navigation ── %>
  <nav class="flex-1 py-2 overflow-y-auto scrollbar-thin">
    <% if defined?(current_user) && current_user %>
      <%# ── Ungrouped Tools ── %>
      <% ungrouped = current_user.ungrouped_tools %>
      <% if ungrouped.any? || current_user.sidebar_groups.any? %>
        <div data-controller="sortable"
             data-sortable-group-value="sidebar-tools"
             data-sortable-url-value="<%= sidebar_positions_path %>"
             data-sortable-param-name-value="tool_ids"
             data-group-id="ungrouped">
          <% ungrouped.each do |instance| %>
            <%= render "shared/sidebar_tool_item", instance: instance %>
          <% end %>
        </div>
      <% end %>

      <%# ── Sidebar Groups (sortable for group reordering) ── %>
      <div data-controller="sortable"
           data-sortable-handle-value=".sidebar-group-header"
           data-sortable-url-value="<%= sidebar_positions_path %>"
           data-sortable-param-name-value="group_ids">
        <% current_user.sidebar_groups.ordered.includes(memberships: { tool: [:tool_type, :mail_account] }).each do |group| %>
          <div class="sidebar-group mt-2" data-sort-id="<%= group.id %>">
            <%# Group header %>
            <div class="sidebar-group-header group/header"
                 data-action="click->sidebar#toggleGroup"
                 data-group-id="<%= group.id %>">
              <span class="sidebar-group-name flex-1 truncate"
                    data-action="dblclick->sidebar#startRename"
                    data-group-id="<%= group.id %>"><%= group.name %></span>
              <div class="sidebar-group-actions">
                <button type="button" class="sidebar-context-btn"
                        data-sidebar-context-btn
                        popovertarget="group-menu-<%= group.id %>"
                        style="anchor-name: --grp-<%= group.id %>">
                  <%= render "shared/icon", name: "more-horizontal", size: 14 %>
                </button>
                <span class="sidebar-group-chevron" data-sidebar-chevron>
                  <%= render "shared/icon", name: "chevron-right", size: 14, class: "transition-transform duration-150 #{group.collapsed? ? '' : 'rotate-90'}" %>
                </span>
              </div>
            </div>

            <%# Per-group context menu %>
            <div id="group-menu-<%= group.id %>" popover="auto"
                 class="popover-menu sidebar-context-menu"
                 style="position-anchor: --grp-<%= group.id %>">
              <button type="button" class="dropdown-item flex items-center gap-2"
                      data-action="click->sidebar#renameFromMenu"
                      data-group-id="<%= group.id %>"
                      popovertarget="group-menu-<%= group.id %>" popovertargetaction="hide">
                <%= render "shared/icon", name: "edit", size: 14 %>
                <span>Rename</span>
              </button>
              <div class="dropdown-divider"></div>
              <%= button_to sidebar_group_path(group), method: :delete,
                    class: "dropdown-item flex items-center gap-2 text-error",
                    data: { turbo_confirm: "Delete this group? Tools will become ungrouped." } do %>
                <%= render "shared/icon", name: "trash-2", size: 14 %>
                <span>Delete Group</span>
              <% end %>
            </div>

            <%# Group tools (sortable, collapsible) %>
            <div class="sidebar-group-content <%= group.collapsed? ? 'hidden' : '' %>"
                 data-sidebar-target="groupContent"
                 data-group-id="<%= group.id %>"
                 data-controller="sortable"
                 data-sortable-group-value="sidebar-tools"
                 data-sortable-url-value="<%= sidebar_group_positions_path(group) %>"
                 data-sortable-param-name-value="tool_ids">
              <% group.memberships.each do |membership| %>
                <% instance = membership.tool %>
                <% next unless instance&.accessible_by?(current_user) %>
                <%= render "shared/sidebar_tool_item", instance: instance %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </nav>

  <%# ── Bottom bar ── %>
  <div class="sidebar-bottom-bar"
       data-controller="notifications"
       data-notifications-user-id-value="<%= current_user.id %>"
       data-notifications-unread-count-value="<%= current_user.notifications.unread.count %>">

    <%# User menu trigger — avatar with name %>
    <button type="button"
            class="sidebar-user-btn"
            popovertarget="sidebar-user-menu"
            style="anchor-name: --sidebar-user-btn">
      <%= render "shared/avatar", user: current_user, size: :sm %>
      <span class="sidebar-user-name"><%= current_user.first_name %></span>
    </button>

    <%# Notifications %>
    <div class="relative flex-shrink-0">
      <button type="button"
              class="sidebar-add-btn relative"
              popovertarget="sidebar-notifications"
              style="anchor-name: --sidebar-notifications-btn"
              data-controller="hotkey"
              data-hotkey="b"
              data-notifications-target="trigger"
              data-action="click->notifications#togglePopover"
              title="Notifications (b)">
        <%= render "shared/icon", name: "bell", size: 16 %>
        <span class="absolute -top-0.5 -right-0.5 badge badge-sm hidden"
              data-notifications-target="badge">
          <%= current_user.notifications.unread.count %>
        </span>
      </button>
      <div id="sidebar-notifications" popover="auto" class="popover-menu sidebar-notifications-popover w-80"
           data-notifications-target="popover">
        <%= turbo_frame_tag "notifications", src: notifications_path, loading: :lazy do %>
          <div class="px-4 py-8 text-center">
            <div class="text-text-tertiary animate-spin">
              <%= render "shared/icon", name: "loader-2", size: 20, class: "mx-auto" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Add menu popover — triggered from the logo bar button above %>
    <div id="sidebar-add-menu" popover="auto" class="popover-menu sidebar-add-popover">
      <button type="button" class="dropdown-item flex items-center gap-2"
              commandfor="new-tool-modal" command="show-modal">
        <%= render "shared/icon", name: "rocket", size: 16 %>
        <span>Add Tool</span>
      </button>
      <%= button_to sidebar_groups_path, params: { name: "New Group" },
            class: "dropdown-item flex items-center gap-2" do %>
        <%= render "shared/icon", name: "folder-plus", size: 16 %>
        <span>New Group</span>
      <% end %>
    </div>

    <%# User menu popover %>
    <div id="sidebar-user-menu" popover="auto" class="popover-menu sidebar-user-popover">
      <div class="px-4 py-3 border-b border-border-light">
        <p class="text-sm font-semibold text-text-primary truncate"><%= current_user.name %></p>
        <p class="text-xs text-text-tertiary truncate mt-0.5"><%= current_user.email_address %></p>
      </div>
      <button type="button" class="dropdown-item flex items-center gap-2"
              commandfor="profile-modal" command="show-modal"
              popovertarget="sidebar-user-menu" popovertargetaction="hide">
        <%= render "shared/icon", name: "user", size: 16 %>
        <span>Profile</span>
      </button>
      <div class="dropdown-divider"></div>
      <%= button_to logout_path, method: :delete, class: "dropdown-item flex items-center gap-2 text-error" do %>
        <%= render "shared/icon", name: "log-out", size: 16 %>
        <span>Sign Out</span>
      <% end %>
    </div>
  </div>

</aside>

<%# ── Modals (outside sidebar to avoid stacking context) ── %>
<% if defined?(current_user) && current_user %>
  <%= render "shared/new_tool_modal" %>
  <%= render "shared/modal", id: "edit-tool-modal", title: "Edit tool", size: :xl,
        data: { sidebar_target: "editToolDialog" } do %>
    <%= turbo_frame_tag "edit-tool-form", data: { sidebar_target: "editToolFrame" } %>
  <% end %>
  <%= render "shared/modal", id: "profile-modal", title: "Profile", size: :xl do %>
    <%= turbo_frame_tag "profile-form", src: edit_profile_path, loading: :lazy do %>
      <div class="px-4 py-8 text-center">
        <div class="text-text-tertiary animate-spin">
          <%= render "shared/icon", name: "loader-2", size: 20, class: "mx-auto" %>
        </div>
      </div>
    <% end %>
  <% end %>
<% end %>
