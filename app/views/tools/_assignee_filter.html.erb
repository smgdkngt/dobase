<%#
  Assignee filter dropdown. Rebuilds the current URL with a different
  ?assignee= param, so it works on any tool view that supports the filter.

  Locals:
    collaborators — array of User
    current       — current assignee filter param (nil / "me" / "unassigned" / id-string)
%>
<%
  current_str  = current.presence
  current_id   = current_str =~ /\A\d+\z/ ? current_str.to_i : nil
  active_user  = current_id ? collaborators.find { |u| u.id == current_id } : nil

  label, trigger_avatar = case current_str
  when nil, ""      then [ "All assignees", nil ]
  when "me"         then [ "Me",            current_user ]
  when "unassigned" then [ "Unassigned",    nil ]
  else
    active_user ? [ active_user.name, active_user ] : [ "All assignees", nil ]
  end

  is_filtered = current_str.present?
%>
<div class="assignee-filter">
  <button type="button"
          class="btn btn-secondary btn-sm <%= 'is-active' if is_filtered %>"
          commandfor="assignee-filter-menu"
          command="toggle-popover"
          style="anchor-name: --assignee-filter">
    <span class="assignee-filter-trigger-leading">
      <% if trigger_avatar %>
        <%= render "shared/avatar", user: trigger_avatar, size: :sm %>
      <% else %>
        <%= render "shared/icon", name: current_str == "unassigned" ? "user" : "users", size: 14 %>
      <% end %>
    </span>
    <span><%= label %></span>
    <%= render "shared/icon", name: "chevron-down", size: 12, class: "text-text-tertiary" %>
  </button>

  <div id="assignee-filter-menu" popover="auto"
       class="popover-menu max-h-72 overflow-y-auto"
       style="position-anchor: --assignee-filter; top: anchor(bottom); left: anchor(left); min-width: anchor-size(width);">
    <%= render "tools/assignee_filter_item",
          href: url_for(assignee: nil),
          label: "All assignees",
          icon: "users",
          selected: current_str.blank? %>

    <%= render "tools/assignee_filter_item",
          href: url_for(assignee: "me"),
          label: "Me",
          user: current_user,
          selected: current_str == "me" %>

    <%= render "tools/assignee_filter_item",
          href: url_for(assignee: "unassigned"),
          label: "Unassigned",
          icon: "user",
          selected: current_str == "unassigned" %>

    <% others = collaborators.reject { |u| u == current_user } %>
    <% if others.any? %>
      <div class="dropdown-divider"></div>
      <% others.each do |user| %>
        <%= render "tools/assignee_filter_item",
              href: url_for(assignee: user.id),
              label: user.name,
              user: user,
              selected: current_id == user.id %>
      <% end %>
    <% end %>
  </div>
</div>
