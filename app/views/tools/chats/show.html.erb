<% content_for(:title) { "#{@tool.name} - #{app_name}" } %>

<% content_for :command_palette_actions do %>
  <%= render "shared/command_palette_action", key: "/", description: "Focus message input", icon: "message-circle" %>
<% end %>

<% content_for :keyboard_shortcuts do %>
  <div>
    <h3 class="text-xs font-semibold text-text-secondary uppercase tracking-wider mb-2">Chat</h3>
    <div class="shortcut-list">
      <%= render "shared/shortcut_row", key: "/", description: "Focus message input" %>
    </div>
  </div>
<% end %>

<div class="tool-layout flex flex-col h-full overflow-hidden"
     data-controller="chat"
     data-chat-chat-id-value="<%= @chat.id %>"
     data-chat-user-id-value="<%= current_user.id %>"
     data-chat-read-url-value="<%= tool_chat_read_path(@tool) %>">
  <button data-controller="hotkey" data-hotkey="/" data-action="click->chat#focusInput" hidden>Focus input</button>

  <%= render "components/tool_topbar", title: @tool.name, tool: @tool do %>
    <!-- Participants avatar stack with popover -->
    <div class="relative" data-controller="popover">
      <button type="button"
              class="flex items-center -space-x-2 hover:opacity-80 transition-opacity"
              data-action="click->popover#toggle"
              aria-label="<%= @participants.count %> participants"
              aria-expanded="false"
              data-popover-target="trigger">
        <% z_classes = %w[z-40 z-30 z-20 z-10] %>
        <% @participants.first(4).each_with_index do |participant, i| %>
          <div class="relative ring-2 ring-surface rounded-full <%= z_classes[i] %>">
            <%= render "shared/avatar", user: participant, size: :sm %>
            <% unless participant.id == current_user.id %>
              <span class="hidden absolute -bottom-0.5 -right-0.5 w-2.5 h-2.5 bg-green-500 border-2 border-surface rounded-full"
                    data-chat-target="onlineIndicator"
                    data-user-id="<%= participant.id %>"></span>
            <% end %>
          </div>
        <% end %>
        <% if @participants.count > 4 %>
          <div class="relative flex items-center justify-center w-8 h-8 rounded-full bg-background-secondary text-text-secondary text-xs font-medium ring-2 ring-surface">
            +<%= @participants.count - 4 %>
          </div>
        <% end %>
      </button>

      <!-- Popover dropdown -->
      <div class="hidden absolute right-0 top-full mt-2 w-64 bg-surface rounded-lg shadow-lg border border-border-light z-50"
           data-popover-target="content">
        <div class="px-3 py-2 border-b border-border-light">
          <span class="text-xs font-semibold text-text-tertiary uppercase tracking-wide">
            Participants (<%= @participants.count %>)
          </span>
        </div>
        <div class="max-h-64 overflow-y-auto py-1">
          <% @participants.each do |participant| %>
            <div class="flex items-center gap-2 px-3 py-2 hover:bg-background-secondary">
              <div class="relative">
                <%= render "shared/avatar", user: participant, size: :sm %>
                <% unless participant.id == current_user.id %>
                  <span class="hidden absolute -bottom-0.5 -right-0.5 w-3 h-3 bg-green-500 border-2 border-surface rounded-full"
                        data-chat-target="onlineIndicator"
                        data-user-id="<%= participant.id %>"></span>
                <% end %>
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-sm font-medium text-text-primary truncate">
                  <%= participant.name %>
                  <% if participant.id == current_user.id %>
                    <span class="text-text-tertiary">(you)</span>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="flex flex-1 overflow-hidden min-h-0">
    <!-- Main chat area -->
    <div class="flex-1 flex flex-col overflow-hidden min-h-0">
      <!-- Messages container -->
      <%= turbo_stream_from @chat %>
      <div class="flex-1 overflow-y-auto px-2 sm:px-4 py-4"
           data-chat-target="messages">
        <div id="chat_messages">
          <% if @messages.any? %>
            <% last_date = nil %>
            <% @messages.each_with_index do |message, index| %>
              <% message_date = message.created_at.to_date %>
              <% if message_date != last_date %>
                <%
                  if message_date == Date.current
                    date_label = "Today"
                  elsif message_date == Date.current - 1
                    date_label = "Yesterday"
                  elsif message_date > Date.current - 7
                    date_label = message_date.strftime("%A")
                  else
                    date_label = message_date.strftime("%B %d, %Y")
                  end
                %>
                <div class="flex items-center gap-3 my-4 sm:my-6 px-2 sm:px-4" role="separator" aria-label="Messages from <%= date_label %>">
                  <div class="flex-1 h-px bg-border-light"></div>
                  <span class="text-xs text-text-tertiary font-medium"><%= date_label %></span>
                  <div class="flex-1 h-px bg-border-light"></div>
                </div>
                <% last_date = message_date %>
              <% end %>
              <%
                # Check if this is a continuation of previous message (same user within 5 minutes)
                prev_message = index > 0 ? @messages[index - 1] : nil
                is_continuation = prev_message &&
                                  prev_message.user_id == message.user_id &&
                                  prev_message.created_at.to_date == message.created_at.to_date &&
                                  (message.created_at - prev_message.created_at) < 5.minutes
              %>
              <%= render partial: "tools/chats/message", locals: { message: message, is_continuation: is_continuation } %>
            <% end %>
          <% end %>

          <div id="chat-empty-state" class="flex items-center justify-center h-full">
            <%= render "components/empty_state",
                title: "No messages yet",
                description: "Start the conversation by sending a message below",
                icon: "message-circle",
                size: :md %>
          </div>
        </div>

        <!-- Typing indicator (outside chat_messages so appended messages don't go after it) -->
        <div id="typing-indicator"
             class="hidden flex gap-3 px-4 py-2"
             data-chat-target="typingIndicator">
          <div class="w-9 sm:w-11 flex-shrink-0"></div>
          <div class="flex-1 flex items-center gap-2">
            <div class="flex gap-1 flex-shrink-0">
              <span class="w-1.5 h-1.5 bg-text-tertiary rounded-full animate-bounce" style="animation-delay: 0ms"></span>
              <span class="w-1.5 h-1.5 bg-text-tertiary rounded-full animate-bounce" style="animation-delay: 150ms"></span>
              <span class="w-1.5 h-1.5 bg-text-tertiary rounded-full animate-bounce" style="animation-delay: 300ms"></span>
            </div>
            <span class="text-sm text-text-tertiary whitespace-nowrap" data-typing-text></span>
          </div>
        </div>
      </div>

      <!-- Message input -->
      <div class="flex flex-col border-t border-border-light bg-surface px-2 sm:px-4 py-2 sm:py-3">
        <!-- Reply preview -->
        <div id="chat-reply-preview"
             class="hidden mb-2"
             data-chat-target="replyPreview">
          <div class="flex items-center gap-2 px-3 py-2 rounded-lg bg-background-secondary">
            <div class="w-0.5 self-stretch bg-accent rounded-full"></div>
            <div class="flex-1 min-w-0">
              <div class="text-xs font-medium text-accent" data-chat-target="replyAuthor"></div>
              <div class="text-sm text-text-secondary line-clamp-1" data-chat-target="replyContent"></div>
            </div>
            <%= render "components/icon_button",
                  icon: "x",
                  title: "Cancel reply",
                  size: :sm,
                  data: { action: "click->chat#cancelReply" } %>
          </div>
        </div>

        <!-- File preview -->
        <div id="chat-file-preview"
             class="hidden mb-2 flex flex-wrap gap-2"
             data-chat-target="filePreview">
        </div>

        <!-- Input with editor + actions -->
        <%= form_with url: tool_chat_messages_path(@tool),
                      method: :post,
                      multipart: true,
                      data: {
                        action: "submit->chat#submit",
                        chat_target: "form"
                      } do |f| %>
          <input type="hidden" name="message[reply_to_id]" value="" data-chat-target="replyToId">
          <input type="file"
                 name="message[files][]"
                 multiple
                 class="hidden"
                 data-chat-target="fileInput"
                 data-action="change->chat#filesSelected">

          <%= render "components/rich_text_input",
                name: "message[body]",
                placeholder: "Type a message...",
                submit_on_enter: true,
                buttons: %w[bold italic code],
                data: {
                  action: "rich-text-input:input->chat#typing"
                } do %>
              <%= render "components/icon_button",
                    icon: "paperclip",
                    title: "Attach files",
                    size: :sm,
                    class: "bg-background-secondary rounded",
                    data: { action: "click->chat#openFilePicker" } %>
              <%= render "components/icon_button",
                    icon: "send",
                    title: "Send message",
                    variant: :accent,
                    size: :sm,
                    class: "rounded",
                    type: :submit %>
          <% end %>
        <% end %>
        <div id="chat-form-errors" class="empty:hidden mt-2"></div>
      </div>
    </div>
  </div>

  <!-- Templates for file preview (must be inside controller scope) -->
  <template data-chat-target="imagePreviewTemplate">
    <div class="relative group/file">
      <img src="" alt="" class="w-16 h-16 object-cover rounded-lg border border-border-light">
      <button type="button"
              class="absolute -top-1 -right-1 w-5 h-5 flex items-center justify-center bg-red-500 text-white rounded-full text-xs opacity-0 group-hover/file:opacity-100 transition-opacity"
              data-action="click->chat#removeFile">&times;</button>
    </div>
  </template>

  <template data-chat-target="filePreviewTemplate">
    <div class="relative group/file">
      <div class="flex items-center gap-2 px-3 py-2 bg-surface rounded-lg border border-border-light">
        <%= render "shared/icon", name: "file", size: 16, class: "text-text-secondary" %>
        <div class="flex flex-col">
          <span class="text-xs text-text-primary truncate max-w-[100px]" data-filename></span>
          <span class="text-[10px] text-text-tertiary" data-filesize></span>
        </div>
      </div>
      <button type="button"
              class="absolute -top-1 -right-1 w-5 h-5 flex items-center justify-center bg-red-500 text-white rounded-full text-xs opacity-0 group-hover/file:opacity-100 transition-opacity"
              data-action="click->chat#removeFile">&times;</button>
    </div>
  </template>
</div>
