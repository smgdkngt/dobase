<% content_for :title, "All Tools - #{app_name}" %>
<% content_for :page_title, "All Tools" %>

<div class="p-6">
<div class="flex items-center justify-between mb-6">
  <p class="text-text-secondary">Manage all your tools in one place.</p>
  <%= render "components/button", text: "Add Tool", icon: "plus", href: new_tool_path %>
</div>

<% if @tools.any? %>
  <div class="card">
    <div class="divide-y divide-border-light">
      <% @tools.each do |tool| %>
        <div class="px-5 py-4 flex items-center gap-4 hover:bg-background-secondary/50 transition-colors">
          <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center flex-shrink-0">
            <%= render "shared/icon", name: tool.tool_type.icon, size: 20, class: "text-accent" %>
          </div>
          <div class="flex-1 min-w-0">
            <%= link_to tool_path(tool), class: "font-medium text-text-primary hover:text-accent" do %>
              <%= tool.name %>
            <% end %>
            <p class="text-sm text-text-secondary"><%= tool.tool_type.name %></p>
          </div>
          <% if tool.owned_by?(current_user) %>
            <span class="text-xs text-text-tertiary">Owner</span>
          <% else %>
            <span class="text-xs text-text-tertiary bg-background-secondary px-2 py-0.5 rounded">Shared</span>
          <% end %>
          <%= render "components/icon_button",
              icon: "chevron-right",
              title: "View",
              size: :sm,
              href: tool_path(tool) %>
        </div>
      <% end %>
    </div>
  </div>
<% else %>
  <div class="card">
    <div class="card-body text-center py-12">
      <div class="w-16 h-16 rounded-full bg-background-secondary flex items-center justify-center mx-auto mb-4">
        <%= render "shared/icon", name: "layout", size: 32, class: "text-text-tertiary" %>
      </div>
      <h4 class="font-medium text-text-primary mb-1">No tools yet</h4>
      <p class="text-text-secondary text-sm mb-4">Get started by adding your first tool.</p>
      <%= render "components/button", text: "Add Your First Tool", icon: "plus", href: new_tool_path %>
    </div>
  </div>
<% end %>
</div>
