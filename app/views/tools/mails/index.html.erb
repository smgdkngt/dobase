<% content_for :title, "#{@tool.name} - #{app_name}" %>
<% content_for :page_title, "" %>

<% content_for :command_palette_actions do %>
  <%= render "shared/command_palette_action", key: "c", description: "Compose", icon: "edit" %>
  <%= render "shared/command_palette_action", key: "/", description: "Search", icon: "search" %>
  <%= render "shared/command_palette_action", key: "e", description: "Archive", icon: "archive" %>
  <%= render "shared/command_palette_action", key: "s", description: "Star / unstar", icon: "star" %>
  <%= render "shared/command_palette_action", key: "r", description: "Reply", icon: "reply" %>
  <%= render "shared/command_palette_action", key: "f", description: "Forward", icon: "forward" %>
  <%= render "shared/command_palette_action", key: "#", description: "Trash", icon: "trash-2" %>
<% end %>

<% content_for :keyboard_shortcuts do %>
  <div>
    <h3 class="text-xs font-semibold text-text-secondary uppercase tracking-wider mb-2">Mail</h3>
    <div class="shortcut-list">
      <%= render "shared/shortcut_row", key: "j", description: "Next message" %>
      <%= render "shared/shortcut_row", key: "k", description: "Previous message" %>
      <%= render "shared/shortcut_row", key: "o", description: "Open message" %>
      <%= render "shared/shortcut_row", key: "c", description: "Compose" %>
      <%= render "shared/shortcut_row", key: "/", description: "Search" %>
      <%= render "shared/shortcut_row", key: "e", description: "Archive" %>
      <%= render "shared/shortcut_row", key: "s", description: "Star / unstar" %>
      <%= render "shared/shortcut_row", key: "u", description: "Mark unread" %>
      <%= render "shared/shortcut_row", key: "#", description: "Trash" %>
      <%= render "shared/shortcut_row", key: "r", description: "Reply" %>
      <%= render "shared/shortcut_row", key: "a", description: "Reply all" %>
      <%= render "shared/shortcut_row", key: "f", description: "Forward" %>
    </div>
  </div>
<% end %>

<div class="tool-layout mail-layout <%= 'mail-detail-open' if @selected_message %>"
     data-controller="mail-keyboard mail-refresh"
     data-mail-refresh-interval-value="<%= @mail_account.auto_refresh_interval || 60 %>"
     data-mail-refresh-url-value="<%= tool_sync_path(@tool) %>">
  <%# Hidden hotkey triggers for keyboard navigation %>
  <button data-controller="hotkey" data-hotkey="j" data-action="click->mail-keyboard#selectNext" hidden>Next</button>
  <button data-controller="hotkey" data-hotkey="k" data-action="click->mail-keyboard#selectPrevious" hidden>Previous</button>
  <button data-controller="hotkey" data-hotkey="o" data-action="click->mail-keyboard#openSelected" hidden>Open</button>
  <button data-controller="hotkey" data-hotkey="Enter" data-action="click->mail-keyboard#openSelected" hidden>Open</button>
  <button data-controller="hotkey" data-hotkey="Escape" data-action="click->mail-keyboard#deselect" hidden>Deselect</button>
  <!-- Top Bar -->
  <div class="mail-topbar flex items-center px-4 py-1 min-h-[53px] gap-3 bg-surface border-b border-border-light col-span-full">
    <h1 class="tool-topbar-title pr-4 mr-1 border-r border-border-light"><%= @tool.name %></h1>

    <!-- Search -->
    <%= render "components/search",
        url: tool_mails_path(@tool),
        value: params[:q],
        placeholder: "Search emails... (/)",
        hidden_fields: { folder: @current_folder },
        data: { turbo_frame: "_top" },
        input_data: { "controller": "hotkey", "hotkey": "/", "mail-keyboard-target": "search" } %>

    <%
      folder_meta = {
        "inbox"   => { label: "Inbox",   icon: "inbox",   badge: @inbox_unread },
        "drafts"  => { label: "Drafts",  icon: "file-pen", badge: @drafts_count },
        "starred" => { label: "Starred", icon: "star" },
        "sent"    => { label: "Sent",    icon: "send" },
        "archive" => { label: "Archive", icon: "archive" },
        "trash"   => { label: "Trash",   icon: "trash-2", badge: @trash_count }
      }
      current_meta = folder_meta[@current_folder] || { label: @current_folder, icon: "folder" }
    %>
    <div class="relative">
      <button type="button"
              class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-background-tertiary transition-colors"
              popovertarget="mail-folder-menu"
              style="anchor-name: --mail-folder-btn">
        <%= render "shared/icon", name: current_meta[:icon], size: 16, class: "text-text-secondary" %>
        <span><%= current_meta[:label] %></span>
        <% if current_meta[:badge].to_i > 0 %>
          <%= render "components/badge", text: current_meta[:badge] %>
        <% end %>
        <%= render "shared/icon", name: "chevron-down", size: 14, class: "text-text-tertiary" %>
      </button>

      <div id="mail-folder-menu" popover="auto" class="popover-menu" style="position-anchor: --mail-folder-btn; position-area: block-end span-inline-start">
        <% folder_meta.each do |key, meta| %>
          <%= link_to tool_mails_path(@tool, folder: key),
                class: "dropdown-item flex items-center gap-2 #{@current_folder == key ? 'text-accent font-medium' : ''}" do %>
            <%= render "shared/icon", name: meta[:icon], size: 16 %>
            <span class="flex-1"><%= meta[:label] %></span>
            <% if meta[:badge].to_i > 0 %>
              <%= render "components/badge", text: meta[:badge], variant: :muted %>
            <% end %>
            <% if @current_folder == key %>
              <%= render "shared/icon", name: "check", size: 14, class: "text-accent" %>
            <% end %>
          <% end %>
        <% end %>
        <% if @custom_folders.any? %>
          <div class="dropdown-divider"></div>
          <% @custom_folders.each do |folder| %>
            <%= link_to tool_mails_path(@tool, folder: folder),
                  class: "dropdown-item flex items-center gap-2 #{@current_folder == folder ? 'text-accent font-medium' : ''}" do %>
              <%= render "shared/icon", name: "folder", size: 16 %>
              <span class="flex-1"><%= folder %></span>
              <% if @current_folder == folder %>
                <%= render "shared/icon", name: "check", size: 14, class: "text-accent" %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
        <div class="dropdown-divider"></div>
        <button type="button"
                class="dropdown-item flex items-center gap-2 w-full"
                commandfor="create-folder-modal" command="show-modal"
                popovertarget="mail-folder-menu" popovertargetaction="hide">
          <%= render "shared/icon", name: "folder-plus", size: 16 %>
          <span>New Folder</span>
        </button>
      </div>
    </div>

    <%= render "shared/modal", id: "create-folder-modal", title: "New Folder", size: :sm do %>
      <%= form_with url: tool_folder_path(@tool), method: :post do %>
        <%= render "components/form_field",
            label: "Folder name",
            name: "folder_name",
            placeholder: "e.g. Receipts",
            required: true,
            autofocus: true %>
        <div class="flex justify-end gap-2 mt-4">
          <%= render "components/button", text: "Cancel", variant: :secondary, type: :button, data: { action: "click->modal#close" } %>
          <%= render "components/button", text: "Create" %>
        </div>
      <% end %>
    <% end %>

    <div class="mail-topbar-actions flex items-center gap-2 ml-auto">
      <div class="flex items-center gap-2 pr-3 mr-2 border-r border-border-light"
           data-controller="sync-status"
           data-sync-status-url-value="<%= tool_sync_path(@tool) %>"
           data-sync-status-syncing-value="<%= @mail_account.syncing? %>">
        <div class="w-1.5 h-1.5 rounded-full <%= @mail_account.synced? ? 'bg-success' : (@mail_account.sync_error? ? 'bg-error' : 'bg-warning') %>"
             data-sync-status-target="indicator"></div>
        <span class="text-xs text-text-tertiary" data-sync-status-target="status">
          <% if @mail_account.syncing? %>
            Syncing...
          <% elsif @mail_account.last_synced_at %>
            <%= time_ago_in_words(@mail_account.last_synced_at) %>
          <% else %>
            Not synced
          <% end %>
        </span>
        <%= render "components/icon_button",
            icon: "refresh-cw",
            title: "Sync now",
            size: :sm,
            href: tool_sync_path(@tool),
            method: :post,
            icon_class: @mail_account.syncing? ? "animate-spin" : nil,
            data: { sync_status_target: "button", action: "click->sync-status#sync" } %>
      </div>

      <%= render "components/button",
          text: "Compose",
          icon: "edit",
          size: :sm,
          href: new_tool_mail_path(@tool),
          data: { controller: "hotkey", hotkey: "c" } %>
    </div>
  </div>

  <!-- Message List -->
  <div class="tool-scroll-area mail-list-panel bg-surface border-r border-border-light overflow-y-auto flex flex-col" data-mail-keyboard-target="list">
    <% if @current_folder == "trash" && @trash_count > 0 %>
      <div class="flex items-center justify-between px-3 py-2 bg-warning-light border-b border-warning text-[0.8125rem] text-warning">
        <span>Messages in Trash are deleted forever after 30 days</span>
        <%= button_to "Empty Trash", tool_empty_trash_path(@tool), method: :delete, class: "text-xs font-medium hover:underline", data: { turbo_confirm: "Permanently delete all messages in Trash?", turbo_confirm_button: "Empty trash" } %>
      </div>
    <% end %>

    <% if params[:q].present? %>
      <div class="px-3 py-2 bg-accent-light border-b border-accent/20">
        <div class="flex items-center justify-between">
          <span class="text-xs text-accent">Search results for "<%= params[:q] %>"</span>
          <%= link_to tool_mails_path(@tool, folder: @current_folder), class: "text-xs text-accent hover:underline" do %>
            Clear search
          <% end %>
        </div>
      </div>
    <% end %>

    <%= form_with url: tool_bulk_path(@tool), method: :post, id: "bulk-form" do %>
      <input type="hidden" name="folder" value="<%= @current_folder %>">

      <% if @conversations.any? %>
        <div class="flex items-center px-3 py-0.5 min-h-9 border-b border-border-light bg-background-secondary gap-3">
          <input type="checkbox" class="w-4 h-4 rounded accent-accent ml-[2px]" id="select-all" onchange="document.querySelectorAll('.mail-list-checkbox').forEach(cb => cb.checked = this.checked); document.getElementById('bulk-actions').classList.toggle('hidden', !this.checked)">
          <div id="bulk-actions" class="flex items-center gap-1 hidden">
            <% if @current_folder == "trash" %>
              <%= render "components/icon_button", icon: "trash-2", title: "Delete forever", type: :submit, name: "action_type", value: "delete", size: :sm %>
              <%= render "components/icon_button", icon: "rotate-ccw", title: "Restore", type: :submit, name: "action_type", value: "restore", size: :sm %>
            <% else %>
              <%= render "components/icon_button", icon: "archive", title: "Archive (e)", type: :submit, name: "action_type", value: "archive", size: :sm %>
              <%= render "components/icon_button", icon: "trash-2", title: "Delete (#)", type: :submit, name: "action_type", value: "trash", size: :sm %>
              <div class="relative">
                <button type="button"
                        class="icon-btn icon-btn-sm"
                        title="Move to folder"
                        popovertarget="bulk-move-menu"
                        style="anchor-name: --bulk-move-btn">
                  <%= render "shared/icon", name: "folder-input", size: 14 %>
                </button>
                <div id="bulk-move-menu" popover="auto" class="popover-menu"
                     style="position-anchor: --bulk-move-btn; position-area: block-end span-inline-start">
                  <%
                    bulk_move_folders = [["INBOX", "inbox", "Inbox"], ["Sent", "send", "Sent"]]
                    @custom_folders.each { |f| bulk_move_folders << [f, "folder", f] }
                  %>
                  <% bulk_move_folders.each do |folder_name, icon, label| %>
                    <button type="button" class="dropdown-item flex items-center gap-2"
                            onclick="const f=this.closest('form');f.querySelector('[name=action_type]')?.remove();const at=document.createElement('input');at.type='hidden';at.name='action_type';at.value='move_to_folder';f.appendChild(at);const tf=document.createElement('input');tf.type='hidden';tf.name='target_folder';tf.value='<%= j folder_name %>';f.appendChild(tf);f.requestSubmit();">
                      <%= render "shared/icon", name: icon, size: 16 %>
                      <span><%= label %></span>
                    </button>
                  <% end %>
                </div>
              </div>
              <%= render "components/icon_button", icon: "mail-open", title: "Mark as read", type: :submit, name: "action_type", value: "mark_read", size: :sm %>
              <%= render "components/icon_button", icon: "mail", title: "Mark as unread (u)", type: :submit, name: "action_type", value: "mark_unread", size: :sm %>
            <% end %>
          </div>
          <span class="text-xs text-text-tertiary ml-auto"><%= @total_count %> messages</span>
        </div>
      <% end %>

      <div class="flex-1 overflow-y-auto">
        <% if @conversations.any? %>
          <%= render partial: "tools/mails/conversation_item",
                  collection: @conversations, as: :conversation,
                  locals: { tool: @tool, current_folder: @current_folder, selected_message: @selected_message } %>

          <% if @total_pages > 1 %>
            <div class="p-3 flex items-center justify-center gap-2 border-t border-border-light">
              <% if @page > 1 %>
                <%= render "components/icon_button",
                    icon: "chevron-left",
                    title: "Previous page",
                    href: tool_mails_path(@tool, folder: @current_folder, page: @page - 1, q: params[:q]) %>
              <% end %>
              <span class="text-xs text-text-tertiary"><%= @page %> / <%= @total_pages %></span>
              <% if @page < @total_pages %>
                <%= render "components/icon_button",
                    icon: "chevron-right",
                    title: "Next page",
                    href: tool_mails_path(@tool, folder: @current_folder, page: @page + 1, q: params[:q]) %>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <%
            folder_icons = { "inbox" => "inbox", "drafts" => "file-pen", "starred" => "star", "sent" => "send", "archive" => "archive", "trash" => "trash-2" }
            folder_descriptions = { "inbox" => "Your inbox is empty", "drafts" => "No drafts", "starred" => "No starred messages", "sent" => "No sent messages", "archive" => "No archived messages", "trash" => "Trash is empty" }
            empty_icon = folder_icons[@current_folder] || "folder"
            empty_title = params[:q].present? ? "No results found" : "No messages"
            empty_description = params[:q].present? ? "Try a different search term" : (folder_descriptions[@current_folder] || "No messages in #{@current_folder}")
          %>
          <%= render "components/empty_state",
              icon: empty_icon,
              title: empty_title,
              description: empty_description %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Email Content (turbo frame — only this panel updates when selecting emails) -->
  <turbo-frame id="mail-content" class="mail-content" target="_top" data-turbo-action="advance">
    <% if @selected_message && @conversation_messages %>
      <%= render "tools/mails/mail_detail" %>
    <% else %>
      <div class="flex flex-col items-center justify-center h-full p-8">
        <div class="w-16 h-16 rounded-full bg-background-tertiary flex items-center justify-center mb-5">
          <%= render "shared/icon", name: "mail", size: 28, class: "text-text-tertiary" %>
        </div>
        <div class="text-base font-semibold text-text-primary mb-1.5">Select a message</div>
        <div class="text-[0.8125rem] text-text-secondary text-center max-w-[260px]">Choose a conversation from the list to view and reply to messages</div>
        <div class="mt-4 text-xs text-text-tertiary">
          <span class="inline-flex items-center gap-1"><kbd class="px-1.5 py-0.5 bg-background-tertiary rounded text-text-secondary">j</kbd>/<kbd class="px-1.5 py-0.5 bg-background-tertiary rounded text-text-secondary">k</kbd> to navigate</span>
          <span class="mx-2">&middot;</span>
          <span class="inline-flex items-center gap-1"><kbd class="px-1.5 py-0.5 bg-background-tertiary rounded text-text-secondary">/</kbd> to search</span>
          <span class="mx-2">&middot;</span>
          <span class="inline-flex items-center gap-1"><kbd class="px-1.5 py-0.5 bg-background-tertiary rounded text-text-secondary">c</kbd> to compose</span>
        </div>
      </div>
    <% end %>
  </turbo-frame>
</div>
