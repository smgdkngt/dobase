<% content_for :title, "Edit #{@tool.name} - #{app_name}" %>
<% content_for :page_title, "Edit Tool" %>

<%
  collabs = @tool.collaborators.includes(:user).order(Arel.sql("CASE WHEN role = 'owner' THEN 0 ELSE 1 END"), :created_at)
  pending_invitations = @tool.invitations.active.order(created_at: :desc)
  declined_invitations = @tool.invitations.declined.order(updated_at: :desc)
  is_mail_tool = @tool.tool_type.slug == "mail"
  mail_account = @tool.mail_account if is_mail_tool
  is_calendar_tool = @tool.tool_type.slug == "calendar"
  calendar_account = @tool.calendar_account if is_calendar_tool
%>

<%= turbo_frame_tag "edit-tool-form" do %>
  <div data-controller="tabs" data-tabs-default-value="settings" class="edit-modal-layout flex -m-5 h-[500px]">
    <%# Vertical tab navigation (horizontal on mobile) %>
    <div class="edit-modal-tabs flex flex-col gap-1 w-44 flex-shrink-0 p-4 border-r border-border-light bg-background-secondary/50">
      <button type="button" class="tab w-full justify-start" data-tabs-target="tab" data-tab="settings" data-action="click->tabs#select">
        <%= render "shared/icon", name: "settings", size: 16 %>
        <span>Settings</span>
      </button>
      <% if is_mail_tool && mail_account %>
        <button type="button" class="tab w-full justify-start" data-tabs-target="tab" data-tab="email" data-action="click->tabs#select">
          <%= render "shared/icon", name: "mail", size: 16 %>
          <span>Email</span>
        </button>
      <% end %>
      <% if is_calendar_tool && calendar_account %>
        <button type="button" class="tab w-full justify-start" data-tabs-target="tab" data-tab="calendar" data-action="click->tabs#select">
          <%= render "shared/icon", name: "calendar", size: 16 %>
          <span>Calendar</span>
        </button>
      <% end %>
      <button type="button" class="tab w-full justify-start" data-tabs-target="tab" data-tab="collaborators" data-action="click->tabs#select">
        <%= render "shared/icon", name: "users", size: 16 %>
        <span>Collaborators</span>
        <% if collabs.any? || pending_invitations.any? %>
          <%= render "components/badge", text: collabs.count + pending_invitations.count, size: :sm %>
        <% end %>
      </button>

      <%# Danger actions — desktop: bottom of sidebar; mobile: inline in tab row %>
      <% can_leave = !@tool.owned_by?(current_user) || @tool.collaborators.owners.count > 1 %>
      <div class="mt-auto pt-2 border-t border-border-light flex flex-col gap-1 max-lg:hidden">
        <% if can_leave %>
          <%= render "components/button",
                text: "Leave",
                variant: :ghost,
                icon: "log-out",
                size: :sm,
                class: "text-error w-full justify-start",
                href: leave_tool_collaborators_path(@tool),
                method: :delete,
                turbo_confirm: "Are you sure you want to leave #{@tool.name}?",
                data: { turbo_frame: "_top", turbo_confirm_button: "Leave" } %>
        <% end %>
        <% if @tool.owned_by?(current_user) %>
          <%= render "components/button",
                text: "Delete",
                variant: :ghost,
                icon: "trash-2",
                size: :sm,
                class: "text-error w-full justify-start",
                href: tool_path(@tool),
                method: :delete,
                turbo_confirm: "Are you sure you want to delete this tool? This action cannot be undone.",
                data: { turbo_frame: "_top", turbo_confirm_button: "Delete" } %>
        <% end %>
      </div>
      <% if can_leave %>
        <%= link_to leave_tool_collaborators_path(@tool),
              class: "tab tab-danger w-full justify-start lg:hidden",
              data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to leave #{@tool.name}?", turbo_confirm_button: "Leave", turbo_frame: "_top" } do %>
          <%= render "shared/icon", name: "log-out", size: 16 %>
          <span>Leave</span>
        <% end %>
      <% end %>
      <% if @tool.owned_by?(current_user) %>
        <%= link_to tool_path(@tool),
              class: "tab tab-danger w-full justify-start lg:hidden",
              data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this tool? This action cannot be undone.", turbo_confirm_button: "Delete", turbo_frame: "_top" } do %>
          <%= render "shared/icon", name: "trash-2", size: 16 %>
          <span>Delete</span>
        <% end %>
      <% end %>
    </div>

    <%# Panel content %>
    <div class="edit-modal-content flex-1 py-4 pr-5 pl-5 overflow-y-auto">
      <%# Settings panel %>
      <div data-tabs-target="panel" data-tab="settings">
        <%= form_with model: @tool, data: { turbo_frame: "_top" } do |f| %>
          <%= render "shared/error_flash", object: @tool %>

          <div class="mb-4">
            <label class="label">Tool Type</label>
            <div class="flex items-center gap-3 p-3 bg-background-secondary rounded-lg">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center">
                <%= render "shared/icon", name: @tool.tool_type.icon, size: 20, class: "text-accent" %>
              </div>
              <span class="font-medium"><%= @tool.tool_type.name %></span>
            </div>
            <p class="help-text">Tool type cannot be changed after creation</p>
          </div>

          <div class="mb-5">
            <label for="tool_name" class="label">Name</label>
            <%= f.text_field :name,
              class: "input #{@tool.errors[:name].any? ? 'input-error' : ''}",
              required: true
            %>
          </div>

          <div class="flex items-center justify-end pt-4 border-t border-border-light">
            <%= render "components/button", text: "Save Changes" %>
          </div>
        <% end %>

      </div>

      <% if is_mail_tool && mail_account %>
        <%# Email settings panel %>
        <div data-tabs-target="panel" data-tab="email" class="hidden">
          <%= form_with model: mail_account, url: tool_mails_account_path(@tool), method: :patch, data: { turbo_frame: "_top" } do |f| %>
            <%= render "shared/error_flash", object: mail_account %>

            <%# Account Details %>
            <div class="mb-5">
              <h3 class="text-sm font-semibold text-text-primary mb-3">Account Details</h3>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label for="mail_account_email_address" class="label">Email Address</label>
                  <%= f.email_field :email_address, class: "input", required: true %>
                </div>
                <div>
                  <label for="mail_account_display_name" class="label">Display Name</label>
                  <%= f.text_field :display_name, class: "input", placeholder: "John Doe" %>
                </div>
              </div>
            </div>

            <%# Credentials %>
            <div class="mb-5">
              <h3 class="text-sm font-semibold text-text-primary mb-3">Credentials</h3>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label for="mail_account_username" class="label">Username</label>
                  <%= f.text_field :username, class: "input", required: true %>
                </div>
                <div>
                  <label for="mail_account_password" class="label">Password</label>
                  <%= f.password_field :password, class: "input", placeholder: "Leave blank to keep current" %>
                </div>
              </div>
            </div>

            <%# IMAP Settings %>
            <div class="mb-5">
              <h3 class="text-sm font-semibold text-text-primary mb-3">IMAP Settings</h3>
              <div class="grid grid-cols-4 gap-3">
                <div class="col-span-3">
                  <label for="mail_account_imap_host" class="label">IMAP Server</label>
                  <%= f.text_field :imap_host, class: "input", required: true %>
                </div>
                <div>
                  <label for="mail_account_imap_port" class="label">Port</label>
                  <%= f.number_field :imap_port, class: "input" %>
                </div>
              </div>
              <label class="flex items-center gap-2 mt-2 cursor-pointer">
                <%= f.check_box :imap_ssl, class: "w-4 h-4 rounded border-border text-accent" %>
                <span class="text-sm text-text-primary">Use SSL/TLS</span>
              </label>
            </div>

            <%# SMTP Settings %>
            <div class="mb-5">
              <h3 class="text-sm font-semibold text-text-primary mb-3">SMTP Settings</h3>
              <div class="grid grid-cols-4 gap-3">
                <div class="col-span-3">
                  <label for="mail_account_smtp_host" class="label">SMTP Server</label>
                  <%= f.text_field :smtp_host, class: "input", required: true %>
                </div>
                <div>
                  <label for="mail_account_smtp_port" class="label">Port</label>
                  <%= f.number_field :smtp_port, class: "input" %>
                </div>
              </div>
              <div class="grid grid-cols-2 gap-3 mt-3">
                <div>
                  <label for="mail_account_smtp_auth" class="label">Authentication</label>
                  <%= f.select :smtp_auth, [["Plain", "plain"], ["Login", "login"], ["CRAM-MD5", "cram_md5"]], {}, class: "input" %>
                </div>
                <div class="flex items-end pb-2">
                  <label class="flex items-center gap-2 cursor-pointer">
                    <%= f.check_box :smtp_tls, class: "w-4 h-4 rounded border-border text-accent" %>
                    <span class="text-sm text-text-primary">Use STARTTLS</span>
                  </label>
                </div>
              </div>
            </div>

            <%# Signature %>
            <div class="mb-5">
              <h3 class="text-sm font-semibold text-text-primary mb-3">Email Signature</h3>
              <%= f.text_area :signature, class: "input min-h-[80px]", rows: 3, placeholder: "Your name\nYour title" %>
            </div>

            <%# Auto-refresh %>
            <div class="mb-5">
              <h3 class="text-sm font-semibold text-text-primary mb-3">Auto-refresh</h3>
              <%= f.select :auto_refresh_interval,
                [["Disabled", 0], ["30 seconds", 30], ["1 minute", 60], ["2 minutes", 120], ["5 minutes", 300]],
                {}, class: "input" %>
            </div>

            <%# Sync Status %>
            <div class="mb-5 p-3 bg-background-secondary rounded-lg">
              <div class="flex items-center justify-between">
                <div>
                  <h4 class="text-sm font-medium text-text-primary">Sync Status</h4>
                  <p class="text-xs text-text-secondary mt-0.5">
                    <% if mail_account.last_synced_at %>
                      Last synced: <%= time_ago_in_words(mail_account.last_synced_at) %> ago
                    <% else %>
                      Never synced
                    <% end %>
                  </p>
                </div>
                <div class="flex items-center gap-2">
                  <div class="w-2 h-2 rounded-full <%= mail_account.synced? ? 'bg-success' : (mail_account.sync_error? ? 'bg-error' : 'bg-warning') %>"></div>
                  <span class="text-sm capitalize"><%= mail_account.sync_status %></span>
                </div>
              </div>
              <% if mail_account.sync_error? && mail_account.sync_error.present? %>
                <p class="text-xs text-error mt-2"><%= mail_account.sync_error %></p>
              <% end %>
            </div>

            <div class="flex items-center justify-end pt-4 border-t border-border-light">
              <%= render "components/button", text: "Save Changes" %>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if is_calendar_tool && calendar_account %>
        <%# Calendar settings panel %>
        <div data-tabs-target="panel" data-tab="calendar" class="hidden">
          <%= form_with model: calendar_account, url: tool_calendar_account_path(@tool), method: :patch, data: { turbo_frame: "_top" } do |f| %>
            <%= render "shared/error_flash", object: calendar_account %>

            <%# Account Type %>
            <div class="mb-5">
              <h3 class="text-sm font-semibold text-text-primary mb-3">Account Type</h3>
              <div class="flex items-center gap-3 p-3 bg-background-secondary rounded-lg">
                <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center">
                  <%= render "shared/icon", name: calendar_account.local? ? "calendar" : "cloud", size: 20, class: "text-accent" %>
                </div>
                <div>
                  <span class="font-medium capitalize"><%= calendar_account.provider %></span>
                  <p class="text-xs text-text-secondary"><%= calendar_account.local? ? "Events stored locally" : "Synced via CalDAV" %></p>
                </div>
              </div>
            </div>

            <% unless calendar_account.local? %>
              <%# CalDAV Settings %>
              <div class="mb-5">
                <h3 class="text-sm font-semibold text-text-primary mb-3">CalDAV Settings</h3>
                <div class="mb-3">
                  <label for="calendars_account_caldav_url" class="label">CalDAV URL</label>
                  <%= f.text_field :caldav_url, class: "input", required: true %>
                </div>
                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <label for="calendars_account_username" class="label">Username</label>
                    <%= f.text_field :username, class: "input", required: true %>
                  </div>
                  <div>
                    <label for="calendars_account_password" class="label">Password</label>
                    <%= f.password_field :password, class: "input", placeholder: "Leave blank to keep current" %>
                  </div>
                </div>
              </div>

              <%# Sync Status %>
              <div class="mb-5 p-3 bg-background-secondary rounded-lg">
                <div class="flex items-center justify-between">
                  <div>
                    <h4 class="text-sm font-medium text-text-primary">Sync Status</h4>
                    <p class="text-xs text-text-secondary mt-0.5">
                      <% if calendar_account.last_synced_at %>
                        Last synced: <%= time_ago_in_words(calendar_account.last_synced_at) %> ago
                      <% else %>
                        Never synced
                      <% end %>
                    </p>
                  </div>
                  <div class="flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full <%= calendar_account.synced? ? 'bg-success' : (calendar_account.sync_error? ? 'bg-error' : 'bg-warning') %>"></div>
                    <span class="text-sm capitalize"><%= calendar_account.sync_status %></span>
                  </div>
                </div>
                <% if calendar_account.sync_error? && calendar_account.sync_error.present? %>
                  <p class="text-xs text-error mt-2"><%= calendar_account.sync_error %></p>
                <% end %>
              </div>
            <% end %>

            <%# Calendars list %>
            <% calendars = calendar_account.calendars.by_position %>
            <% if calendars.any? %>
              <div class="mb-5">
                <h3 class="text-sm font-semibold text-text-primary mb-3">Calendars</h3>
                <div class="space-y-2">
                  <% calendars.each do |calendar| %>
                    <div class="flex items-center gap-3 p-3 bg-background-secondary rounded-lg">
                      <input type="hidden" name="calendars_account[calendars_attributes][<%= calendar.id %>][id]" value="<%= calendar.id %>">
                      <input type="color"
                             name="calendars_account[calendars_attributes][<%= calendar.id %>][color]"
                             value="<%= calendar.color_hex %>"
                             class="w-6 h-6 rounded cursor-pointer border-0 p-0">
                      <input type="text"
                             name="calendars_account[calendars_attributes][<%= calendar.id %>][name]"
                             value="<%= calendar.name %>"
                             class="flex-1 text-sm font-medium bg-transparent border-0 p-0 focus:outline-none focus:ring-0">
                      <% if calendar.is_default? %>
                        <span class="text-xs text-text-tertiary">Default</span>
                      <% end %>
                      <label class="flex items-center gap-2 cursor-pointer">
                        <input type="hidden" name="calendars_account[calendars_attributes][<%= calendar.id %>][enabled]" value="0">
                        <input type="checkbox"
                               name="calendars_account[calendars_attributes][<%= calendar.id %>][enabled]"
                               value="1"
                               <%= "checked" if calendar.enabled? %>
                               class="w-4 h-4 rounded border-border text-accent">
                        <span class="text-xs text-text-secondary">Visible</span>
                      </label>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>

            <div class="flex items-center justify-end pt-4 border-t border-border-light">
              <%= render "components/button", text: "Save Changes" %>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# Collaborators panel %>
      <div data-tabs-target="panel" data-tab="collaborators" class="hidden">
        <%# Member list (owners + collaborators) %>
        <div id="collaborator-list">
          <%= render partial: "shared/collaborator_row",
                collection: collabs, as: :collaborator,
                locals: { tool: @tool } %>
        </div>

        <%# Pending invitations %>
        <div id="invitation-list">
          <%= render partial: "shared/invitation_row",
                collection: pending_invitations, as: :invitation,
                locals: { tool: @tool } %>
        </div>

        <%# Declined invitations %>
        <% if declined_invitations.any? %>
          <div id="declined-invitation-list">
            <% declined_invitations.each do |invitation| %>
              <div class="flex items-center justify-between py-2 opacity-60">
                <div class="collaborator-info">
                  <%= render "shared/avatar", initials: invitation.email[0].upcase, size: :sm %>
                  <div>
                    <div class="collaborator-name">
                      <%= invitation.email %>
                      <span class="inline-block text-[0.625rem] font-semibold text-error bg-error/10 px-1.5 py-px rounded-full ml-1.5 uppercase tracking-wide">Declined</span>
                    </div>
                    <div class="collaborator-email">Declined <%= time_ago_in_words(invitation.updated_at) %> ago</div>
                  </div>
                </div>
                <% if @tool.owned_by?(current_user) %>
                  <%= button_to tool_resend_invitation_path(@tool, invitation),
                        method: :post,
                        class: "text-xs text-accent bg-transparent border-none cursor-pointer px-2 py-1 rounded-sm hover:bg-accent-light" do %>
                    Reinvite
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# Empty state %>
        <div id="collaborator-empty"
             class="text-center py-3 text-text-tertiary text-sm <%= (collabs.any? || pending_invitations.any? || declined_invitations.any?) ? 'hidden' : '' %>">
          No collaborators yet. Add someone by email below.
        </div>

        <% if @tool.owned_by?(current_user) %>
          <div class="border-t border-border-light my-2"></div>

          <%# Add collaborator form (owners only) %>
          <%= form_with url: tool_collaborators_path(@tool),
                class: "flex gap-2 items-center" do |f| %>
            <div class="flex-1">
              <%= f.email_field :email, class: "input", placeholder: "Enter email address...", required: true %>
            </div>
            <%= render "components/button", text: "Add" %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
