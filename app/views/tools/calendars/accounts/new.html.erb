<% content_for :title, "Setup Calendar - #{@tool.name} - #{app_name}" %>
<% content_for :page_title, "Setup Calendar Account" %>

<div class="p-6" data-controller="calendar-setup">
  <div class="max-w-2xl">
    <div class="card">
      <div class="card-header">
        <h2 class="text-lg font-semibold">Set up your calendar</h2>
        <p class="text-sm text-text-secondary mt-1">Create a local calendar or connect to a CalDAV server</p>
      </div>
      <div class="card-body">
        <%= form_with model: @calendar_account, url: tool_calendar_account_path(@tool), method: :post, data: { turbo: false } do |f| %>
          <%= render "shared/error_flash", object: @calendar_account %>

          <!-- Provider Selection -->
          <div class="mb-6">
            <h3 class="text-sm font-semibold text-text-primary mb-3">Choose Type</h3>
            <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
              <% [
                { name: "Local", value: "local", icon: "calendar", description: "No sync" },
                { name: "iCloud", value: "icloud", icon: "cloud", description: "Apple" },
                { name: "Fastmail", value: "fastmail", icon: "mail", description: "CalDAV" },
                { name: "Nextcloud", value: "nextcloud", icon: "server", description: "CalDAV" },
                { name: "Other", value: "custom", icon: "settings", description: "CalDAV" }
              ].each do |provider| %>
                <label class="provider-card cursor-pointer">
                  <%= f.radio_button :provider, provider[:value],
                      class: "hidden",
                      data: { action: "change->calendar-setup#toggleProvider", calendar_setup_target: "providerRadio" } %>
                  <div class="provider-card-content">
                    <div class="w-10 h-10 rounded-full bg-accent-light flex items-center justify-center mb-2">
                      <%= render "shared/icon", name: provider[:icon], size: 20, class: "text-accent" %>
                    </div>
                    <span class="text-sm font-medium text-text-primary"><%= provider[:name] %></span>
                    <span class="text-xs text-text-tertiary"><%= provider[:description] %></span>
                  </div>
                </label>
              <% end %>
            </div>
          </div>

          <!-- Local calendar info -->
          <div class="mb-6 p-4 bg-background-secondary rounded-lg hidden" data-calendar-setup-target="localInfo">
            <div class="flex items-start gap-3">
              <%= render "shared/icon", name: "info", size: 20, class: "text-accent flex-shrink-0 mt-0.5" %>
              <div>
                <h4 class="text-sm font-medium text-text-primary mb-1">Local Calendar</h4>
                <p class="text-sm text-text-secondary">Events are stored locally and won't sync to external services. You can always connect to CalDAV later.</p>
              </div>
            </div>
          </div>

          <!-- CalDAV fields (hidden for local) -->
          <div data-calendar-setup-target="caldavFields">
            <!-- CalDAV URL -->
            <div class="mb-6">
              <h3 class="text-sm font-semibold text-text-primary mb-3">Server Settings</h3>
              <div>
                <label for="calendar_account_caldav_url" class="label">CalDAV URL</label>
                <%= f.text_field :caldav_url,
                  class: "input #{@calendar_account.errors[:caldav_url].any? ? 'input-error' : ''}",
                  placeholder: "https://caldav.example.com/principals/username/"
                %>
                <p class="help-text">Your calendar server's CalDAV endpoint URL</p>
              </div>
            </div>

            <!-- Credentials -->
            <div class="mb-6">
              <h3 class="text-sm font-semibold text-text-primary mb-3">Credentials</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label for="calendar_account_username" class="label">Username</label>
                  <%= f.text_field :username,
                    class: "input #{@calendar_account.errors[:username].any? ? 'input-error' : ''}",
                    placeholder: "you@example.com"
                  %>
                  <p class="help-text">Usually your email address</p>
                </div>
                <div>
                  <label for="calendar_account_password" class="label">Password</label>
                  <%= f.password_field :password,
                    class: "input #{@calendar_account.errors[:encrypted_password].any? ? 'input-error' : ''}",
                    placeholder: "App password or password"
                  %>
                  <p class="help-text">Use an app password if available</p>
                </div>
              </div>
            </div>

            <!-- Common Presets Help -->
            <div class="mb-6 p-4 bg-background-secondary rounded-lg">
              <h4 class="text-sm font-medium text-text-primary mb-2">Common Settings</h4>
              <div class="text-xs text-text-secondary space-y-1">
                <p><strong>iCloud:</strong> https://caldav.icloud.com/ (Use app-specific password)</p>
                <p><strong>Fastmail:</strong> https://caldav.fastmail.com/dav/calendars/user/username@fastmail.com/</p>
                <p><strong>Nextcloud:</strong> https://nextcloud.example.com/remote.php/dav/calendars/username/</p>
              </div>
            </div>
          </div>

          <div class="flex items-center justify-end gap-3">
            <%= render "components/button", text: "Cancel", href: tool_path(@tool), variant: :secondary %>
            <button type="submit" class="btn btn-primary" data-calendar-setup-target="submitButton">
              <span data-calendar-setup-target="submitText">Connect Account</span>
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
