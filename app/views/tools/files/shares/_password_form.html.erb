<div class="max-w-[400px] text-center p-8">
  <div class="flex justify-center text-text-tertiary mb-6">
    <%= render "shared/icon", name: "lock", size: 48 %>
  </div>
  <h1 class="text-xl font-semibold mb-2">Password Required</h1>
  <p class="text-text-secondary mb-6">This shared content is password protected.</p>

  <%= form_with url: share_path(@share.token), method: :get, class: "text-left" do %>
    <div class="mb-4">
      <label class="label" for="password">Password</label>
      <input type="password" name="password" id="password" class="input" required autofocus>
      <% if @password_error %>
        <p class="text-red-500 text-sm mt-1"><%= @password_error %></p>
      <% end %>
    </div>
    <%= render "components/button", text: "Unlock", variant: :primary, full_width: true %>
  <% end %>
</div>
