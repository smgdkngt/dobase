<%#
  Navigation Pill Button component

  A button for use inside nav_pill component.

  Options:
    icon: Icon name (renders icon button)
    text: Button text (renders text button)
    title: Tooltip text
    data: Data attributes hash

  Examples:
    render "components/nav_pill_button", icon: "chevron-left", title: "Previous", data: { action: "controller#prev" }
    render "components/nav_pill_button", text: "Today", data: { action: "controller#today" }
%>
<%
  html_options = {
    type: :button,
    title: local_assigns[:title],
    data: local_assigns[:data]
  }.compact
%>

<% if local_assigns[:icon] %>
  <% html_options[:class] = "p-1.5 rounded-full hover:bg-white/20 transition-colors" %>
  <%= tag.button(**html_options) { render "shared/icon", name: icon, size: 18 } %>
<% elsif local_assigns[:text] %>
  <% html_options[:class] = "px-2 py-0.5 text-xs font-medium rounded-full hover:bg-white/20 transition-colors" %>
  <%= tag.button(**html_options) { text } %>
<% end %>
